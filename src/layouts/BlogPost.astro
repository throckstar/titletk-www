---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  heroImage?: string;
}

const { title, description, date, author, category, heroImage } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Base title={`${title} — Title TK`} description={description}>

  <!-- Nav -->
  <header class="post-nav">
    <a href="/" class="post-nav-logo">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
        <path d="M 22 8 C 14 8, 11 12, 11 20 L 11 28 C 11 30.5, 9 31.5, 6 32 C 9 32.5, 11 33.5, 11 36 L 11 44 C 11 52, 14 56, 22 56"/>
        <path d="M 42 8 C 50 8, 53 12, 53 20 L 53 28 C 53 30.5, 55 31.5, 58 32 C 55 32.5, 53 33.5, 53 36 L 53 44 C 53 52, 50 56, 42 56"/>
      </svg>
      title tk
    </a>
    <a href="/journal" class="post-nav-back">← Journal</a>
  </header>

  <!-- Cover — Editorial Typeset -->
  <div class="post-cover">
    <div class="cover-top-row">
      <span class="cover-eyebrow">{category ?? 'Field Notes'}</span>
    </div>
    <h1 class="cover-title">{title} <span class="tk-badge">tk</span></h1>
    <div class="cover-bottom-row">
      <div class="cover-meta">
        {author && <span>{author}</span>}
        <span>{dateStr}</span>
      </div>
      <div class="cover-rule"></div>
    </div>
  </div>

  <!-- Post body -->
  <article class="post-body">
    {heroImage && (
      <div class="post-hero-image">
        <img src={heroImage} alt="" loading="lazy" />
      </div>
    )}
    <slot />
  </article>

  <!-- Footer -->
  <footer class="post-footer">
    <a href="/journal" class="post-footer-back">← Back to Journal</a>
    <a href="mailto:partners@titletk.co" class="post-footer-cta">Get in touch</a>
  </footer>

</Base>

<style>
  /* Nav */
  .post-nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 96px; height: 64px;
    background: var(--tk-parchment);
    border-bottom: 1px solid var(--tk-rule);
  }
  .post-nav-logo {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--tk-display); font-weight: 700; font-size: 16px;
    color: var(--tk-ink); text-decoration: none; letter-spacing: -0.015em;
  }
  .post-nav-back {
    font-family: var(--tk-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--tk-ink-3); text-decoration: none;
  }
  .post-nav-back:hover { color: var(--tk-ink); }

  /* Cover */
  .post-cover {
    background: var(--tk-parchment);
    padding: 80px 96px 72px;
    display: flex; flex-direction: column;
    justify-content: space-between; gap: 36px;
    min-height: 420px;
    border-bottom: 1px solid var(--tk-rule);
  }
  .cover-top-row {
    display: flex; justify-content: space-between; align-items: center;
  }
  .cover-eyebrow {
    font-family: var(--tk-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--tk-orange-deep);
  }
  .cover-title {
    font-family: var(--tk-display); font-weight: 700;
    font-size: clamp(40px, 7vw, 116px);
    line-height: 0.92; letter-spacing: -0.025em;
    color: var(--tk-ink); margin: 0;
    display: inline;
  }
  .tk-badge {
    display: inline-flex; align-items: center;
    font-family: var(--tk-mono); font-weight: 500;
    font-size: clamp(12px, 1.6vw, 28px);
    background: var(--tk-yellow); color: var(--tk-ink);
    padding: 0.1em 0.45em; border-radius: 3px;
    letter-spacing: 0.04em; vertical-align: 0.2em;
    margin-left: 0.25em;
  }
  .cover-bottom-row {
    display: flex; justify-content: space-between; align-items: center;
  }
  .cover-meta {
    display: flex; gap: 20px; align-items: center;
    font-family: var(--tk-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--tk-ink-3);
  }
  .cover-meta span + span::before {
    content: '/'; margin-right: 20px; opacity: 0.4;
  }
  .cover-rule {
    height: 2px; width: 80px; background: var(--tk-ink);
  }

  /* Post body */
  .post-body {
    max-width: 720px; margin: 0 auto;
    padding: 80px 56px 120px;
    font-family: var(--tk-sans); font-size: 18px; line-height: 1.7;
    color: var(--tk-ink-2);
  }
  .post-hero-image {
    margin-bottom: 56px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--tk-rule);
  }
  .post-hero-image img {
    width: 100%; height: auto; display: block;
  }
  .post-body :global(h2) {
    font-family: var(--tk-display); font-weight: 700;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.1; letter-spacing: -0.02em;
    color: var(--tk-ink); margin: 56px 0 20px;
  }
  .post-body :global(h3) {
    font-family: var(--tk-display); font-weight: 600; font-size: 22px;
    color: var(--tk-ink); margin: 40px 0 14px;
  }
  .post-body :global(p) { margin: 0 0 24px; }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 24px; margin: 0 0 24px;
  }
  .post-body :global(li) { margin-bottom: 10px; }
  .post-body :global(hr) {
    border: 0; border-top: 1px solid var(--tk-rule); margin: 48px 0;
  }
  .post-body :global(blockquote) {
    margin: 32px 0; padding: 0 0 0 24px;
    border-left: 3px solid var(--tk-orange);
    color: var(--tk-ink); font-size: 20px; line-height: 1.5;
  }
  .post-body :global(code) {
    font-family: var(--tk-mono); font-size: 14px;
    background: var(--tk-parchment); padding: 2px 6px; border-radius: 3px;
  }

  /* Footer */
  .post-footer {
    border-top: 1px solid var(--tk-rule);
    padding: 32px 96px;
    display: flex; justify-content: space-between; align-items: center;
    background: var(--tk-paper);
  }
  .post-footer-back {
    font-family: var(--tk-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--tk-ink-3); text-decoration: none;
  }
  .post-footer-back:hover { color: var(--tk-ink); }
  .post-footer-cta {
    display: inline-flex; align-items: center;
    background: var(--tk-ink); color: var(--tk-paper);
    font-family: var(--tk-sans); font-weight: 500; font-size: 14px;
    padding: 10px 22px; border-radius: 999px; text-decoration: none;
    transition: background 160ms ease;
  }
  .post-footer-cta:hover { background: var(--tk-orange); color: var(--tk-ink); }

  /* Tablet — reduce wide horizontal padding */
  @media (max-width: 1024px) {
    .post-nav,
    .post-footer { padding-left: 56px; padding-right: 56px; }
    .post-cover { padding: 64px 56px 56px; min-height: 360px; }
  }

  @media (max-width: 768px) {
    .post-nav,
    .post-footer { padding-left: 24px; padding-right: 24px; }
    .post-cover { padding: 48px 24px; min-height: auto; }
    .post-body { padding: 48px 24px 80px; font-size: 16px; }
    .post-body .post-hero-image { margin-bottom: 40px; }
    .post-footer { flex-direction: column; gap: 16px; align-items: flex-start; }
    .cover-rule { display: none; }
  }
</style>
