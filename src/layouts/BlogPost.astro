---
import Base from './Base.astro';

type AccentColor = 'coral-20' | 'coral-50' | 'coral-100' | 'yellow-20' | 'yellow-50' | 'yellow-100';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  heroImage?: string;
  heroPortrait?: string;
  accentColor?: AccentColor;
  issueNumber?: number;
}

const {
  title,
  description,
  date,
  author,
  category,
  heroPortrait,
  accentColor = 'coral-50',
  issueNumber,
} = Astro.props;

const accentMap: Record<AccentColor, string> = {
  'coral-20':  '#FFDEDE',
  'coral-50':  '#FFADAD',
  'coral-100': '#FF8A8A',
  'yellow-20': '#FFF9D6',
  'yellow-50': '#FFF0A0',
  'yellow-100':'#FFE259',
};

const accent = accentMap[accentColor];
const dateStr = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const issueStr = issueNumber != null ? String(issueNumber).padStart(2, '0') : null;
---

<Base title={`${title} — Title TK`} description={description}>

  <!-- Nav — dark -->
  <header class="post-nav">
    <a href="/" class="post-nav-logo">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
        <path d="M 22 8 C 14 8, 11 12, 11 20 L 11 28 C 11 30.5, 9 31.5, 6 32 C 9 32.5, 11 33.5, 11 36 L 11 44 C 11 52, 14 56, 22 56"/>
        <path d="M 42 8 C 50 8, 53 12, 53 20 L 53 28 C 53 30.5, 55 31.5, 58 32 C 55 32.5, 53 33.5, 53 36 L 53 44 C 53 52, 50 56, 42 56"/>
      </svg>
      title tk
    </a>
    <a href="/journal" class="post-nav-back">← Journal</a>
  </header>

  <!-- Split Hero -->
  <div class="post-hero">
    <div
      class="hero-left"
      style={heroPortrait
        ? `background-image:url(${heroPortrait});background-size:cover;background-position:center`
        : `background:${accent}`}
    >
      {heroPortrait && (
        <div class="hero-portrait-overlay" style={`background:${accent}`}></div>
      )}
      {issueStr && <div class="hero-ghost">{issueStr}</div>}
      <div class="hero-left-top">
        <span class="hero-eyebrow">{category ?? 'Field Notes'}</span>
      </div>
      <div class="hero-left-bottom">
        <span class="hero-date">{dateStr}</span>
        {author && <span class="hero-author">{author}</span>}
      </div>
    </div>
    <div class="hero-right">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-lede">{description}</p>
    </div>
  </div>

  <!-- Post body -->
  <section class="post-body-section">
    <article class="post-body">
      <div class="post-byline">
        <div class="post-byline-text">
          <span class="post-byline-name">{author ?? 'Title TK'}</span>
          <span class="post-byline-meta">{dateStr} · Field Notes</span>
        </div>
      </div>
      <slot />
    </article>
  </section>

  <!-- Footer — dark -->
  <footer class="post-footer">
    <a href="/journal" class="post-footer-back">← Back to Journal</a>
    <a href="mailto:partners@titletk.co" class="post-footer-cta" style={`background:${accent};color:var(--tk-ink)`}>Get in touch →</a>
  </footer>

</Base>

<style define:vars={{ accent, accentBg: accent }}>
  /* ── Nav ──────────────────────────────────────────────────── */
  .post-nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 64px; height: 64px;
    background: var(--tk-ink);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .post-nav-logo {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--tk-display); font-weight: 700; font-size: 16px;
    color: var(--tk-paper); text-decoration: none; letter-spacing: -0.015em;
  }
  .post-nav-back {
    font-family: var(--tk-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.45); text-decoration: none;
    transition: color 160ms ease;
  }
  .post-nav-back:hover { color: var(--tk-paper); }

  /* ── Split Hero ───────────────────────────────────────────── */
  .post-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }
  .hero-left {
    position: relative;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 48px 56px;
    overflow: hidden;
  }
  .hero-portrait-overlay {
    position: absolute; inset: 0;
    opacity: 0.75;
    z-index: 0;
  }
  .hero-ghost {
    position: absolute;
    bottom: -0.12em; right: -0.04em;
    font-family: var(--tk-display); font-weight: 900;
    font-size: clamp(140px, 20vw, 300px);
    line-height: 1; letter-spacing: -0.04em;
    color: rgba(0,0,0,0.07);
    pointer-events: none; user-select: none;
    z-index: 1;
  }
  .hero-left-top  { position: relative; z-index: 2; }
  .hero-left-bottom {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; gap: 4px;
  }
  .hero-eyebrow {
    font-family: var(--tk-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--tk-ink);
  }
  .hero-date {
    font-family: var(--tk-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(26,24,21,0.55);
  }
  .hero-author {
    font-family: var(--tk-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(26,24,21,0.55);
  }
  .hero-right {
    background: var(--tk-parchment);
    display: flex; flex-direction: column; justify-content: center;
    padding: 64px 72px;
    border-left: 1px solid var(--tk-rule);
  }
  .hero-title {
    font-family: var(--tk-display); font-weight: 700;
    font-size: clamp(32px, 4vw, 64px);
    line-height: 1.0; letter-spacing: -0.025em;
    color: var(--tk-ink); margin: 0 0 24px;
  }
  .hero-lede {
    font-family: var(--tk-sans); font-size: 18px; line-height: 1.6;
    color: var(--tk-ink-2); margin: 0;
  }

  /* ── Post Body ────────────────────────────────────────────── */
  .post-body-section { background: var(--tk-paper); }

  .post-body {
    max-width: 700px; margin: 0 auto;
    padding: 80px 40px 120px;
    font-family: var(--tk-sans); font-size: 18px; line-height: 1.75;
    color: var(--tk-ink-2);
  }

  /* Author byline */
  .post-byline {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 0 32px;
    border-bottom: 1px solid var(--tk-rule);
    margin-bottom: 48px;
  }
  .post-byline-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .post-byline-name {
    font-family: var(--tk-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--tk-ink);
  }
  .post-byline-meta {
    font-family: var(--tk-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tk-ink-3);
  }

  /* First paragraph — larger and lighter */
  .post-body :global(p:first-of-type) {
    font-size: 21px; line-height: 1.65;
    color: var(--tk-ink-3); margin-bottom: 32px;
  }
  .post-body :global(p) { margin: 0 0 24px; }

  .post-body :global(h2) {
    font-family: var(--tk-display); font-weight: 700;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.1; letter-spacing: -0.02em;
    color: var(--tk-ink); margin: 56px 0 20px;
  }
  .post-body :global(h3) {
    font-family: var(--tk-display); font-weight: 600; font-size: 22px;
    color: var(--tk-ink); margin: 40px 0 14px;
  }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 24px; margin: 0 0 24px;
  }
  .post-body :global(li) { margin-bottom: 10px; }
  .post-body :global(hr) {
    border: 0; border-top: 1px solid var(--tk-rule); margin: 48px 0;
  }

  /* Pull quote */
  .post-body :global(blockquote) {
    margin: 2.5em 0 2.5em 32px;
    padding: 0 0 0 24px;
    border-left: 3px solid var(--accentBg);
    background: none;
    border-radius: 0;
  }
  .post-body :global(blockquote p) {
    font-family: var(--tk-narrow);
    font-style: italic;
    font-size: 22px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--tk-ink);
    margin: 0;
  }

  /* Post image — bumps out past column */
  .post-body :global(.post-image) {
    margin: 2.5em -48px;
    border: none;
    background: none;
    min-height: unset;
    display: block;
  }
  .post-body :global(.post-image img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }
  .post-body :global(figcaption) {
    font-family: var(--tk-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--tk-ink-3);
    padding: 10px 48px 0;
    text-align: left;
  }

  .post-body :global(code) {
    font-family: var(--tk-mono); font-size: 14px;
    background: var(--tk-parchment); padding: 2px 6px; border-radius: 3px;
  }

  /* ── Footer ───────────────────────────────────────────────── */
  .post-footer {
    background: var(--tk-ink);
    padding: 40px 64px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .post-footer-back {
    font-family: var(--tk-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none;
    transition: color 160ms ease;
  }
  .post-footer-back:hover { color: rgba(255,255,255,0.9); }
  .post-footer-cta {
    display: inline-flex; align-items: center;
    font-family: var(--tk-sans); font-weight: 600; font-size: 14px;
    padding: 10px 22px; border-radius: 999px; text-decoration: none;
    transition: opacity 160ms ease;
  }
  .post-footer-cta:hover { opacity: 0.8; }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .post-nav  { padding: 0 40px; }
    .hero-left { padding: 40px 40px; }
    .hero-right { padding: 48px 48px; }
    .post-footer { padding: 32px 40px; }
  }

  @media (max-width: 768px) {
    .post-nav { padding: 0 24px; }
    .post-hero { grid-template-columns: 1fr; }
    .hero-left { min-height: 200px; padding: 32px 24px; }
    .hero-ghost { font-size: clamp(100px, 32vw, 160px); }
    .hero-right { padding: 40px 24px; border-left: none; border-top: 1px solid var(--tk-rule); }
    .hero-title { font-size: clamp(28px, 7vw, 48px); }
    .post-body { padding: 48px 24px 80px; font-size: 17px; }
    .post-body :global(p:first-of-type) { font-size: 19px; }
    .post-body :global(blockquote) { margin: 2em -24px; padding: 24px; }
    .post-body :global(.post-image) { margin: 2em -24px; }
    .post-footer { padding: 28px 24px; flex-direction: column; gap: 16px; align-items: flex-start; }
  }
</style>
