---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['All', 'Strategy', 'Field Notes', 'Press', 'Studio'];

// Cover colors for the card thumbnails
const coverColors: Record<string, string> = {
  editorial: 'var(--tk-parchment)',
  ticker:    'var(--tk-ink)',
  index:     '#FAF7F2',
  staggered: 'var(--tk-parchment)',
};
---

<Base title="Journal — Title TK" description="Stories, field notes, and strategy from Title TK.">
  <!-- Nav -->
  <header class="nav">
    <a href="/" class="nav-logo">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
        <path d="M 22 8 C 14 8, 11 12, 11 20 L 11 28 C 11 30.5, 9 31.5, 6 32 C 9 32.5, 11 33.5, 11 36 L 11 44 C 11 52, 14 56, 22 56"/>
        <path d="M 42 8 C 50 8, 53 12, 53 20 L 53 28 C 53 30.5, 55 31.5, 58 32 C 55 32.5, 53 33.5, 53 36 L 53 44 C 53 52, 50 56, 42 56"/>
      </svg>
      title tk
    </a>
    <a href="mailto:partners@titletk.co" class="nav-cta">Get in touch</a>
  </header>

  <!-- Page header -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="eyebrow">Journal</div>
      <h1>Stories &amp; field notes</h1>
      <div class="filters">
        {categories.map(cat => (
          <span class="filter-chip" data-cat={cat}>{cat}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Post grid -->
  <main class="grid-wrap">
    {posts.length === 0 ? (
      <p class="empty">No posts yet. Check back soon.</p>
    ) : (
      <div class="post-grid">
        {posts.map(post => {
          const cover = post.data.cover ?? 'editorial';
          const bg = coverColors[cover] ?? coverColors.editorial;
          const dateStr = post.data.date.toLocaleDateString('en-US', {
            month: 'long', day: 'numeric', year: 'numeric'
          });
          return (
            <a href={`/journal/${post.slug}`} class="post-card" data-cat={post.data.category ?? 'Field Notes'}>
              <div class="card-cover" style={`background:${bg}`}>
                {cover === 'ticker' && (
                  <div class="card-ticker">SIG-0217 ▸ FED MINUTES ▸ SIG-0218 ▸ CHIP REGS ▸</div>
                )}
                {cover === 'staggered' && (
                  <div class="card-stripes">
                    <div style="width:18%;background:var(--tk-coral)"></div>
                    <div style="width:7%;background:var(--tk-parchment)"></div>
                    <div style="width:26%;background:var(--tk-yellow)"></div>
                    <div style="flex:1;background:var(--tk-parchment)"></div>
                    <div style="width:15%;background:var(--tk-orange)"></div>
                  </div>
                )}
                <div class="card-cover-label" style={cover === 'ticker' ? 'color:rgba(255,255,255,.7)' : ''}>
                  {post.data.category ?? 'Field Notes'}
                </div>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  <span class="card-tag">{post.data.category ?? 'Field Notes'}</span>
                  <span>{dateStr}</span>
                </div>
                <h2 class="card-title">{post.data.title}</h2>
                <p class="card-desc">{post.data.description}</p>
                <span class="card-read">Read story →</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span>© Title TK 2026</span>
      <a href="mailto:partners@titletk.co">partners@titletk.co</a>
      <span>San Francisco · Marin</span>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  .nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 56px; height: 64px;
    background: var(--tk-parchment);
    border-bottom: 1px solid var(--tk-rule);
  }
  .nav-logo {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--tk-display); font-weight: 700; font-size: 16px;
    color: var(--tk-ink); text-decoration: none; letter-spacing: -0.015em;
  }
  .nav-cta {
    display: inline-flex; align-items: center;
    background: var(--tk-ink); color: var(--tk-paper);
    font-family: var(--tk-sans); font-weight: 500; font-size: 14px;
    padding: 8px 20px; border-radius: 999px; text-decoration: none;
    transition: background 160ms ease;
  }
  .nav-cta:hover { background: var(--tk-orange); color: var(--tk-ink); }

  /* Page header */
  .page-header {
    background: var(--tk-parchment);
    border-bottom: 1px solid var(--tk-rule);
    padding: 64px 0 48px;
  }
  .page-header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 56px;
  }
  .eyebrow {
    font-family: var(--tk-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--tk-ink-3);
    margin-bottom: 16px;
  }
  h1 {
    font-family: var(--tk-display); font-weight: 700;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.95; letter-spacing: -0.025em;
    color: var(--tk-ink); margin: 0 0 32px;
  }
  .filters {
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .filter-chip {
    font-family: var(--tk-sans); font-size: 14px; font-weight: 500;
    padding: 6px 16px; border-radius: 999px;
    border: 1px solid var(--tk-rule-strong);
    color: var(--tk-ink-3); cursor: pointer;
    transition: all 160ms ease;
  }
  .filter-chip.active,
  .filter-chip[data-cat="All"] {
    background: var(--tk-ink); color: var(--tk-paper); border-color: var(--tk-ink);
  }

  /* Grid */
  .grid-wrap {
    max-width: 1200px; margin: 0 auto; padding: 56px 56px 96px;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 40px;
  }
  .empty {
    font-family: var(--tk-mono); font-size: 13px; color: var(--tk-ink-3);
    letter-spacing: 0.1em; text-transform: uppercase; padding: 48px 0;
  }

  /* Post card */
  .post-card {
    display: flex; flex-direction: column; gap: 20px;
    text-decoration: none; color: inherit;
  }
  .post-card:hover .card-title { color: var(--tk-orange-deep); }
  .card-cover {
    position: relative; overflow: hidden;
    border-radius: 6px; height: 240px;
  }
  .card-ticker {
    position: absolute; top: 0; left: 0; right: 0;
    background: var(--tk-orange); color: var(--tk-ink);
    height: 32px; display: flex; align-items: center;
    font-family: var(--tk-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.12em; white-space: nowrap; overflow: hidden;
    border-bottom: 2px solid var(--tk-ink); padding: 0 16px;
  }
  .card-stripes {
    position: absolute; inset: 0; display: flex;
  }
  .card-cover-label {
    position: absolute; bottom: 16px; left: 16px;
    font-family: var(--tk-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--tk-ink-3);
  }
  .card-body { display: flex; flex-direction: column; gap: 10px; }
  .card-meta {
    display: flex; gap: 14px; align-items: center;
    font-family: var(--tk-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--tk-ink-3);
  }
  .card-tag { color: var(--tk-coral-deep); }
  .card-title {
    font-family: var(--tk-display); font-weight: 600;
    font-size: 26px; line-height: 1.15; letter-spacing: -0.015em;
    color: var(--tk-ink); margin: 0;
    transition: color 160ms ease;
  }
  .card-desc {
    font-size: 15px; line-height: 1.55; color: var(--tk-ink-2); margin: 0;
  }
  .card-read {
    font-family: var(--tk-sans); font-size: 13px; font-weight: 500;
    color: var(--tk-ink); border-bottom: 1px solid var(--tk-ink);
    padding-bottom: 2px; width: fit-content;
  }

  /* Footer */
  .site-footer {
    background: var(--tk-ink); color: rgba(255,255,255,.55);
    padding: 32px 56px;
  }
  .footer-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; gap: 32px; align-items: center;
    font-family: var(--tk-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
  }
  .footer-inner a { color: rgba(255,255,255,.55); text-decoration: none; }
  .footer-inner a:hover { color: rgba(255,255,255,.9); }

  @media (max-width: 768px) {
    .nav, .page-header-inner, .grid-wrap { padding-left: 24px; padding-right: 24px; }
    .post-grid { grid-template-columns: 1fr; }
    .site-footer { padding: 24px; }
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
</style>

<script>
  // Filter chips
  const chips = document.querySelectorAll<HTMLElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      const cat = chip.dataset.cat;
      cards.forEach(card => {
        card.style.display = (cat === 'All' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>
